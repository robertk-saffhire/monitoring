# Supabase PostgreSQL connection string
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@YOUR_HOST:5432/postgres"

# Used for local login sessions
JWT_SECRET="generate-a-long-random-secret"

# Optional email notification settings
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Phase 1C local migration settings
# These are for running migration scripts from your computer.
# Do not commit real data exports or private URLs.
MIGRATION_COMPANY_SLUG="driver-pipeline"
MIGRATION_COMPANY_NAME="Driver Pipeline"
# MIGRATION_COMPANY_ID="1"

# Optional Google Apps Script source URLs for local migration export/import
GOOGLE_APPLICANTS_URL=""
GOOGLE_NOTES_URL=""
GOOGLE_MED_EXPIRE_URL=""
GOOGLE_MED_CERTS_URL=""
