{
  "include": ["vite.config.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "server",
    "drizzle",
    "client",
    "shared",
    "scripts",
    "migration",
    "references",
    "**/*.test.ts"
  ],
  "compilerOptions": {
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["vite/client"]
  }
}
